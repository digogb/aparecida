# Copie este arquivo para .env na VM: cp .env.production.example .env
# NUNCA commite o .env real no repositório.

# --- Banco de dados ---
DB_PASSWORD=troque_por_senha_forte

# --- Autenticação ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque_por_chave_aleatoria_64_chars

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gmail / Google Cloud ---
GMAIL_CREDENTIALS_PATH=/app/credentials/gmail_service_account.json
GMAIL_SENDER_EMAIL=escritorio@gmail.com
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
